{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new/investment-account-schema.json",
  "title": "Investment Account",
  "description": "An investment holding or account tracked for simulation and goal planning.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "investment_account_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "account_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 150
    },
    "instrument_type": {
      "type": "string",
      "enum": [
        "mutual_fund",
        "stock",
        "etf",
        "epf",
        "nps",
        "ppf",
        "ssy",
        "savings_account",
        "fixed_deposit",
        "gold",
        "other"
      ]
    },
    "asset_type": {
      "type": "string",
      "enum": [
        "equity",
        "debt",
        "gold",
        "hybrid",
        "cash",
        "other"
      ]
    },
    "asset_sub_type": {
      "type": "string",
      "enum": [
        "large_cap",
        "mid_cap",
        "small_cap",
        "multi_cap",
        "flexi_cap",
        "international_equity",
        "government_debt",
        "corporate_debt",
        "provident_fund",
        "retirement_hybrid",
        "liquid_cash",
        "physical_gold",
        "gold_etf",
        "other"
      ]
    },
    "fund_category": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "provider_name": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "folio_or_account_reference": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    },
    "linked_income_stream_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "description": "Optional link for salary-derived investments such as EPF or NPS."
    },
    "contribution_mode": {
      "type": "string",
      "enum": [
        "manual",
        "fixed_amount",
        "percentage_of_income"
      ]
    },
    "contribution_frequency": {
      "type": "string",
      "enum": [
        "monthly",
        "quarterly",
        "half_yearly",
        "yearly",
        "none"
      ]
    },
    "contribution_amount": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "contribution_percentage": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "contribution_source": {
      "type": "string",
      "enum": [
        "self",
        "employer",
        "mixed",
        "not_applicable"
      ]
    },
    "opening_value": {
      "type": "number",
      "minimum": 0
    },
    "current_value": {
      "type": "number",
      "minimum": 0
    },
    "expected_return_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_bucket": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "maturity_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "liquidity_type": {
      "type": "string",
      "enum": [
        "liquid",
        "semi_liquid",
        "locked_in"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "closed"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "investment_account_id",
    "user_id",
    "account_name",
    "instrument_type",
    "asset_type",
    "asset_sub_type",
    "contribution_mode",
    "contribution_frequency",
    "contribution_source",
    "opening_value",
    "current_value",
    "expected_return_rate",
    "risk_bucket",
    "start_date",
    "liquidity_type",
    "status",
    "created_at",
    "updated_at"
  ]
}
