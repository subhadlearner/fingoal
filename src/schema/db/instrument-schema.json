{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://fingoal.com/schemas/instrument-schema.json",
    "title": "Investment Instrument",
    "type": "object",
    "properties": {
        "instrument_id": {
            "type": "string",
            "description": "Primary Key for database (UUID).",
            "format": "uuid",
            "readOnly": true
        },
        "goal_id": {
            "type": "string",
            "description": "ID of the goal to which the instrument belongs.",
            "format": "uuid",
            "readOnly": true
        },
        "instrument_name": {
            "type": "string",
            "title": "Instrument Name",
            "description": "Name of the investment instrument.",
            "writeOnly": false,
            "minLength": 1,
            "maxLength": 100,
            "ui_type": "text"
        },
        "instrument_type": {
            "title": "Instrument Type",
            "description": "Type of the financial instrument for example - Mutual Fund",
            "enum": [
                "Mutual Fund",
                "Government Scheme",
                "ETF",
                "Stock Option",
                "Fixed Deposit",
                "Savings Account"
            ],
            "writeOnly": false,
            "ui_type": "dropdown"
        },
        "instrument_status": {
            "title": "Instrument Status",
            "description": "Current status of the investment instrument.",
            "enum": [
                "Active",
                "Paused",
                "Stopped"
            ],
            "writeOnly": false,
            "ui_type": "dropdown"
        },
        "instrument_tax_liability": {
            "type": "number",
            "title": "Instrument Tax Liability",
            "description": "Tax liability associated with the investment instrument.",
            "minimum": 0,
            "readOnly": true
        },
        "instrument_tax_liability_now": {
            "type": "number",
            "title": "Instrument Tax Liability",
            "description": "Tax liability associated with the investment instrument.",
            "minimum": 0,
            "readOnly": true
        },
        "fund_category": {
            "type": "string",
            "title": "Fund Category",
            "description": "Category of the fund. For example, Flexicap, Large Cap, Mid Cap etc. Applicable for only Mutual Funds.",
            "minLength": 1,
            "maxLength": 100,
            "writeOnly": false,
            "ui_type": "text"
        },
        "frequency": {
            "title": "Frequency",
            "description": "Frequency of the investment.",
            "enum": [
                "Monthly",
                "Annually"
            ],
            "writeOnly": false,
            "ui_type": "dropdown"
        },
        "asset_type": {
            "title": "Asset Type",
            "description": "Type of the asset.",
            "enum": [
                "Equity",
                "Debt",
                "Hybrid",
                "Gold"
            ],
            "writeOnly": false,
            "ui_type": "dropdown"
        },
        "asset_sub_type": {
            "title": "Asset Sub-Type",
            "description": "Sub-type of the asset.",
            "enum": [
                "Equity India",
                "Equity US",
                "Equity International except US",
                "Debt Government",
                "Debt Corporate",
                "Debt SavingsAccount",
                "Debt FixedDeposit",
                "Hybrid India",
                "Gold"
            ],
            "writeOnly": false,
            "ui_type": "dropdown"
        },
        "hybrid_allocation": {
            "type": "array",
            "items": {
                "$ref": "hybrid-allocation-schema.json"
            },
            "description": "Allocation breakdown for hybrid assets. Applicable only if asset_type is Hybrid.",
            "writeOnly": false
        },
        "start_date": {
            "type": "string",
            "title": "Start Date",
            "description": "Date when the investment was started.",
            "format": "date",
            "writeOnly": false,
            "ui_type": "date"
        },
        "end_date": {
            "type": "string",
            "title": "End Date",
            "description": "Date when the investment ends.",
            "format": "date",
            "writeOnly": false,
            "ui_type": "date"
        },
        "expected_roi": {
            "type": "number",
            "title": "Expected ROI",
            "description": "Expected rate of return for the investment instrument.",
            "minimum": 0.0,
            "maximum": 1.0,
            "writeOnly": false,
            "default": 0.12,
            "ui_type": "number"
        },
        "expected_corpus": {
            "type": "number",
            "title": "Expected Corpus",
            "description": "Expected corpus value for the investment instrument.",
            "minimum": 0.0,
            "readOnly": true
        },
        "ytd_corpus": {
            "type": "number",
            "title": "YTD Corpus",
            "description": "Year-to-date corpus value for the investment instrument.",
            "minimum": 0.0,
            "writeOnly": false,
            "ui_type": "number"
        },
        "instrument_start_amount": {
            "type": "number",
            "title": "Instrument Start Amount",
            "description": "Initial amount invested in the instrument.",
            "minimum": 0.0,
            "writeOnly": false,
            "ui_type": "number"
        },
        "step_up_type": {
            "title": "Step-Up Type",
            "description": "Type of step-up for the investment instrument.",
            "enum": [
                "SalaryLinked",
                "Manual",
                "AutomaticYoY",
                "Not Applicable"
            ],
            "writeOnly": false,
            "ui_type": "dropdown"
        },
        "step_up_percentage": {
            "type": "number",
            "title": "Step-Up Percentage",
            "description": "Percentage by which the investment amount will increase. Only applicable for AutomaticYoY ste-up type.",
            "minimum": 0.1,
            "maximum": 1.0,
            "writeOnly": false,
            "ui_type": "slider"
        },
        "investment_schedule": {
            "type": "array",
            "items": {
                "$ref": "schedule-schema.json"
            },
            "writeOnly": false
        },
        "transactions": {
            "type": "array",
            "items": {
                "$ref": "transaction-schema.json"
            },
            "readOnly": true
        }
    },
    "required": [
        "instrument_id",
        "goal_id",
        "instrument_name",
        "instrument_type",
        "asset_type",
        "ytd_corpus",
        "instrument_start_amount",
        "start_date",
        "expected_roi",
        "asset_sub_type",
        "frequency",
        "instrument_status"
    ],
    "allOf": [
        {
            "description": "Rule 1: If it is a Mutual Fund, require fund_category",
            "if": {
                "properties": {
                    "instrument_type": {
                        "const": "Mutual Fund"
                    }
                }
            },
            "then": {
                "required": [
                    "fund_category"
                ]
            }
        },
        {
            "description": "Rule 2: If asset_type is Hybrid, require hybrid_details",
            "if": {
                "properties": {
                    "asset_type": {
                        "const": "Hybrid"
                    }
                }
            },
            "then": {
                "required": [
                    "hybrid_allocation"
                ]
            }
        },
        {
            "description": "Rule 3: If step_up_type is AutomaticYoY, require step_up_percentage",
            "if": {
                "properties": {
                    "step_up_type": {
                        "const": "AutomaticYoY"
                    }
                }
            },
            "then": {
                "required": [
                    "step_up_percentage"
                ]
            }
        },
        {
            "description": "Rule 4: If step_up_type is Manual, require investment_schedule",
            "if": {
                "properties": {
                    "step_up_type": {
                        "const": "Manual"
                    }
                }
            },
            "then": {
                "required": [
                    "investment_schedule"
                ]
            }
        }
    ]
}