{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://fingoal.com/schemas/schedule-schema.json",
    "title": "Investment Schedule",
    "type": "object",
    "properties": {
        "schedule_id": {
            "type": "string",
            "description": "Primary Key for database (UUID).",  
            "format": "uuid"
        },
        "schedule_name": {
            "type": "string",
            "title": "Schedule Name",
            "description": "Name of the investment schedule."
        },
        "date": {
            "type": "string",
            "title": "Date",
            "description": "Date of the investment schedule.",
            "format": "date"
        },
        "amount": {
            "type": "number",
            "title": "Amount",
            "description": "Amount of the investment schedule.",
            "minimum": 0
        }
    },
    "required": [
        "schedule_id",
        "date",
        "amount"
    ]
}