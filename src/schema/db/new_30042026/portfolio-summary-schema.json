{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new_30042026/portfolio-summary-schema.json",
  "title": "Portfolio Summary",
  "description": "System-calculated portfolio-level corpus, allocation, and progress summary for a user.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "portfolio_summary_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "as_of_date": {
      "type": "string",
      "format": "date"
    },
    "portfolio_current_corpus": {
      "type": "number",
      "minimum": 0
    },
    "portfolio_projected_corpus": {
      "type": "number",
      "minimum": 0
    },
    "portfolio_current_equity_allocation": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "portfolio_current_debt_allocation": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "portfolio_current_gold_allocation": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "portfolio_current_other_allocation": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "total_goal_target_corpus": {
      "type": "number",
      "minimum": 0
    },
    "total_goal_current_corpus": {
      "type": "number",
      "minimum": 0
    },
    "total_goal_projected_corpus": {
      "type": "number",
      "minimum": 0
    },
    "overall_goal_progress_percentage": {
      "type": "number",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "portfolio_summary_id",
    "user_id",
    "as_of_date",
    "portfolio_current_corpus",
    "portfolio_projected_corpus",
    "portfolio_current_equity_allocation",
    "portfolio_current_debt_allocation",
    "portfolio_current_gold_allocation",
    "portfolio_current_other_allocation",
    "total_goal_target_corpus",
    "total_goal_current_corpus",
    "total_goal_projected_corpus",
    "overall_goal_progress_percentage",
    "created_at",
    "updated_at"
  ]
}
