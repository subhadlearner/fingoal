{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new_30042026/income-schema.json",
  "title": "Income",
  "description": "Salary income configuration for Phase-1 projection.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "income_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "income_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "default": "Salary"
    },
    "income_type": {
      "type": "string",
      "enum": ["salary"],
      "default": "salary"
    },
    "monthly_gross_salary": {
      "type": "number",
      "minimum": 0
    },
    "annual_salary_hike_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "bonus_month": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 12,
      "description": "Month in which bonus is paid. Null means no bonus configured."
    },
    "bonus_percentage_of_annual_gross": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 0
    },
    "projection_start_month": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$",
      "description": "First projection month in YYYY-MM format."
    },
    "projection_end_month": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$",
      "description": "Usually the user's retirement month in YYYY-MM format."
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "closed"],
      "default": "active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "income_id",
    "user_id",
    "income_name",
    "income_type",
    "monthly_gross_salary",
    "annual_salary_hike_percentage",
    "bonus_percentage_of_annual_gross",
    "projection_start_month",
    "projection_end_month",
    "status",
    "created_at",
    "updated_at"
  ]
}
