{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new/goal-allocation-schema.json",
  "title": "Goal Allocation",
  "description": "Maps part or all of an investment account to a financial goal.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "goal_allocation_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "goal_id": {
      "type": "string",
      "format": "uuid"
    },
    "investment_account_id": {
      "type": "string",
      "format": "uuid"
    },
    "allocation_method": {
      "type": "string",
      "enum": [
        "percentage",
        "absolute_value"
      ]
    },
    "allocation_percentage": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "allocation_amount": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "effective_from": {
      "type": "string",
      "format": "date"
    },
    "effective_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "is_active": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "goal_allocation_id",
    "user_id",
    "goal_id",
    "investment_account_id",
    "allocation_method",
    "effective_from",
    "is_active",
    "created_at",
    "updated_at"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "allocation_method": {
            "const": "percentage"
          }
        }
      },
      "then": {
        "required": [
          "allocation_percentage"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "allocation_method": {
            "const": "absolute_value"
          }
        }
      },
      "then": {
        "required": [
          "allocation_amount"
        ]
      }
    }
  ]
}
