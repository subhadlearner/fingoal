{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new/transaction-schema.json",
  "title": "Investment Transaction",
  "description": "Cash flow or holding movement recorded against an investment account.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "transaction_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "investment_account_id": {
      "type": "string",
      "format": "uuid"
    },
    "transaction_type": {
      "type": "string",
      "enum": [
        "buy",
        "sell",
        "contribution",
        "withdrawal",
        "dividend",
        "interest_credit",
        "fee",
        "tax",
        "opening_balance"
      ]
    },
    "transaction_date": {
      "type": "string",
      "format": "date"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "units": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "price_per_unit": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "fees": {
      "type": "number",
      "minimum": 0
    },
    "tax_amount": {
      "type": "number",
      "minimum": 0
    },
    "source": {
      "type": "string",
      "enum": [
        "manual",
        "imported",
        "system_generated"
      ]
    },
    "external_reference": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 150
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "transaction_id",
    "user_id",
    "investment_account_id",
    "transaction_type",
    "transaction_date",
    "amount",
    "fees",
    "tax_amount",
    "source",
    "created_at",
    "updated_at"
  ]
}
