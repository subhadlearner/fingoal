{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new/goal-schema.json",
  "title": "Goal",
  "description": "Financial goal defined by the user and used in projection analysis.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "goal_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "goal_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "goal_category": {
      "type": "string",
      "enum": [
        "retirement",
        "emergency_fund",
        "home_purchase",
        "education",
        "marriage",
        "vacation",
        "vehicle",
        "wealth_creation",
        "other"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "must_have",
        "important",
        "aspirational"
      ]
    },
    "target_year": {
      "type": "integer",
      "minimum": 2024
    },
    "target_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "current_estimated_cost": {
      "type": "number",
      "minimum": 0,
      "description": "Present-day estimated cost of the goal."
    },
    "goal_inflation_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Goal-specific annual inflation assumption."
    },
    "future_target_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Inflation-adjusted target amount computed by the system."
    },
    "current_funded_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Current value of mapped investments allocated to this goal."
    },
    "target_allocation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "equity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "debt": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "gold": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "other": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "equity",
        "debt",
        "gold",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "paused",
        "cancelled"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "goal_id",
    "user_id",
    "goal_name",
    "goal_category",
    "priority",
    "target_year",
    "current_estimated_cost",
    "goal_inflation_rate",
    "future_target_amount",
    "current_funded_amount",
    "target_allocation",
    "status",
    "created_at",
    "updated_at"
  ]
}
