{
    "schema_owner": "Subhadeep Majumder",
    "schema_name": "user_schema",
    "schema_version": "1.1",
    "data_constraints": {
        "user_genders": [
            "Male",
            "Female",
            "Other"
        ],
        "user_marital_statuses": [
            "Married",
            "Unmarried"
        ],
        "user_risk_profiles": [
            "Aggressive",
            "Moderate",
            "Conservative"
        ]
    },
    "attribute_definitions": {
        "user_id": {
            "data_type": "String",
            "description": "Primary Key for database. Use UUID or unique slug.",
            "source": "SYSTEM_GENERATED"
        },
        "user_name": {
            "Label": "Full Name",
            "data_type": "String",
            "description": "Full name of the user.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_email": {
            "Label": "Email Address",
            "data_type": "String",
            "description": "Email address of the user.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_pan": {
            "Label": "PAN Number",
            "data_type": "String",
            "description": "PAN number of the user for tax calculations.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_phone": {
            "Label": "Phone Number",
            "data_type": "String",
            "description": "Phone number of the user.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_dob": {
            "Label": "Date of Birth",
            "data_type": "DateTime",
            "description": "Date of birth of the user for age calculations.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_retirement_age": {
            "Label": "At what age do you want to stop working for money?",
            "data_type": "Integer",
            "description": "Expected retirement age of the user for retirement goal calculations.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_gender": {
            "Label": "Gender",
            "data_type": "Enum",
            "description": "Gender of the user.",
            "source": "USER_INPUT",
            "options_ref": "data_constraints.user_genders"
        },
        "user_occupation": {
            "Label": "Occupation",
            "data_type": "String",
            "description": "Occupation of the user for risk profiling.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_marital_status": {
            "Label": "Marital Status",
            "data_type": "Enum",
            "description": "Marital status of the user for risk profiling.",
            "source": "USER_INPUT",
            "options_ref": "data_constraints.user_marital_statuses"
        },
        "user_risk_profile": {
            "Label": "Risk Profile",
            "data_type": "Enum",
            "description": "Risk profile of the user for investment recommendations.",
            "source": "USER_INPUT",
            "options_ref": "data_constraints.user_risk_profiles"
        },
        "user_current_monthly_expense": {
            "Label": "Current Monthly Expense to cover your Needs",
            "data_type": "Float",
            "description": "Current monthly expense of the user for expense planning.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_monthly_expense_cap": {
            "Label": "Monthly Expense Cap",
            "data_type": "Float",
            "description": "Maximum monthly expense user is willing to have in the future for expense planning.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_expense_inflation_rate": {
            "Label": "Expense Inflation Rate",
            "data_type": "Float",
            "description": "Expected annual inflation rate for user's expenses for expense planning.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        },
        "user_emergency_fund_no_of_months": {
            "Label": "Emergency Fund (in months of expenses)",
            "data_type": "Integer",
            "description": "Number of months of expenses user wants to keep as emergency fund for emergency fund calculations.",
            "source": "USER_INPUT",
            "validation": "REQUIRED"
        }
    },
    "user_data": {
        "user_id": "user_1",
        "user_name": "John Doe",
        "user_email": "john.doe@example.com",
        "user_pan": "ABCDE1234F",
        "user_phone": "+91 9876543210",
        "user_dob": "1990-01-01",
        "user_retirement_age": 58,
        "user_gender": "Male",
        "user_occupation": "Engineer",
        "user_marital_status": "Married",
        "user_risk_profile": "Moderate",
        "user_current_monthly_expense": 100000,
        "user_monthly_expense_cap": 115000,
        "user_expense_inflation_rate": 0.05,
        "user_emergency_fund_no_of_months": 6
    }
}