{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new_30042026/goal-investment-allocation-schema.json",
  "title": "Goal Investment Allocation",
  "description": "Percentage allocation of an investment instrument to a financial goal.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "goal_investment_allocation_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "goal_id": {
      "type": "string",
      "format": "uuid"
    },
    "investment_id": {
      "type": "string",
      "format": "uuid"
    },
    "allocation_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentage of the investment allocated to this goal."
    },
    "allocated_current_corpus": {
      "type": "number",
      "minimum": 0,
      "description": "System-calculated current corpus from this investment for this goal."
    },
    "allocated_projected_corpus": {
      "type": "number",
      "minimum": 0,
      "description": "System-calculated projected corpus from this investment for this goal."
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "goal_investment_allocation_id",
    "user_id",
    "goal_id",
    "investment_id",
    "allocation_percentage",
    "allocated_current_corpus",
    "allocated_projected_corpus",
    "is_active",
    "created_at",
    "updated_at"
  ]
}
