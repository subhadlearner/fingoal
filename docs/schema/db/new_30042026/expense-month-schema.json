{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new_30042026/expense-month-schema.json",
  "title": "Expense Month",
  "description": "Persisted monthly expense projection record.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "expense_month_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "expense_id": {
      "type": "string",
      "format": "uuid"
    },
    "year": {
      "type": "integer",
      "minimum": 1900
    },
    "month": {
      "type": "integer",
      "minimum": 1,
      "maximum": 12
    },
    "month_key": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
    },
    "expense_amount": {
      "type": "number",
      "minimum": 0
    },
    "applied_expense_increase_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "source": {
      "type": "string",
      "enum": ["simulation", "user_override"],
      "description": "The latest source of this monthly value."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "expense_month_id",
    "user_id",
    "expense_id",
    "year",
    "month",
    "month_key",
    "expense_amount",
    "applied_expense_increase_percentage",
    "source",
    "created_at",
    "updated_at"
  ]
}
