{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fingoal.com/schemas/new_29042026/goal-allocation-schema.json",
  "title": "Goal Allocation",
  "description": "Maps one full investment account corpus to one financial goal for Phase-1.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "goal_allocation_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "goal_id": {
      "type": "string",
      "format": "uuid"
    },
    "investment_account_id": {
      "type": "string",
      "format": "uuid"
    },
    "allocation_percentage": {
      "type": "integer",
      "const": 100,
      "description": "Phase-1 always allocates 100% of an instrument corpus to one goal."
    },
    "allocated_current_value": {
      "type": "number",
      "minimum": 0
    },
    "is_active": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "goal_allocation_id",
    "user_id",
    "goal_id",
    "investment_account_id",
    "allocation_percentage",
    "allocated_current_value",
    "is_active",
    "created_at",
    "updated_at"
  ]
}
